/* 1400 ms */
@keyframes jiggle {
  0% {
    transform: rotate(0);
  }

  14.3% {
    transform: rotate(11deg);
  }

  28.6% {
    transform: rotate(0deg);
  }

  35.7% {
    transform: rotate(-8deg);
  }

  46.4% {
    transform: rotate(0);
  }

  46.4% {
    transform: rotate(0);
  }

  53.6% {
    transform: rotate(3deg);
  }

  64.3% {
    transform: rotate(0);
  }

  71.4% {
    transform: rotate(-1deg);
  }

  82.1% {
    transform: rotate(0);
  }

