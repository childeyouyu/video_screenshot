}

@keyframes star {
  from {
    background-position: 0 0;
  }

  to {
    background-position: -340px 0;
  }
}

.cardBgRoot .star {
  display: inline-block;
  background-image: url('https://i0.hdslb.com/bfs/activity-plat/static/20240521/6fdde5f06d0b876f68573682fa59da66/a8DG0BREmj.png');
  background-size: 340px 20px;
  background-repeat: no-repeat;
  width: 20px;
  height: 20px;
  animation: star .85s steps(17);
}

@keyframes light {
  from {
    background-position: -100% 0;
  }

  to {
    background-position: 42px 0;
  }
}

.cardBgRoot .cardBg {
  display: inline-block;
  position: relative;
  user-select: none;
  height: 48px;
  max-width: 288px;
  overflow: hidden;
}

.cardBgRoot .cardBg .fanTextPosition {
  position: absolute;
  right: 0;
  top: 0;
}

.cardBgRoot .cardBgH5 {
  display: flex;
  align-items: center;
  height: 40px;
}

.cardBgRoot .cardBgH5 .fanText {
  font-size: 8px;
  line-height: 10px;
  transform: none;
}

.cardBgRoot .fanText {
  height: 100%;
  font-size: 13px;
  line-height: 16px;
  transform: scale(.7);
  transform-origin: center center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
}

.cardBgRoot .fanText >span {
  font-family: 'fans-num', sans-serif !important;
}

.cardBgRoot .specialMedal {
  user-select: none;
  display: flex;
  align-items: center;
  position: relative;
  height: 40px;
}

.cardBgRoot .specialMedal .fanText {
  font-size: 8px;
  line-height: 10px;
  transform: none;
}

.cardBgRoot .specialMedal .medalImgAnimation {
  animation: jiggle 1.4s linear;
}

.cardBgRoot .specialMedal .star {
  position: absolute;
  top: 3px;
  left: 17px;
}

.cardBgRoot .specialMedal .fanTextWrap {
  position: relative;
}

.cardBgRoot .specialMedal .textMask {
  position: absolute;
  left: 0;
  top: 0;
  background-image: url('https://i0.hdslb.com/bfs/activity-plat/static/20240522/6fdde5f06d0b876f68573682fa59da66/BalugIvNR2.png');
  background-size: auto 100%;
  background-repeat: no-repeat;
  background-position: -100% 0;
  animation: light 1.1s linear;
  color: transparent;
  background-clip: text;
  -webkit-background-clip: text;
}

.cardBgRoot .specialMedalPc {
  padding: 7px 12px;
  display: inline-block;
  height: 48px;
  max-width: 288px;
  overflow: hidden;
  box-sizing: border-box;
}

.cardBgRoot .specialMedalPc .specialMedal {
  height: 33px;
}

.cardBgRoot .specialMedalPc .medalImg {
  width: 33px !important;
  height: 33px !important;
}

.cardBgRoot .specialMedalPc .star {
  transform: scale(.8);
  transform-origin: left top;
  left: 14px;
  top: 2px;
}

.cardBgRoot .specialMedalPc .fanText {
  font-size: 9px;
  line-height: 11px;
}

.cardBgRoot .cardGameMedalPc {
  padding: 7px 6px 7px 12px;
  display: inline-block;
  height: 48px;
  max-width: 288px;
  overflow: hidden;
  box-sizing: border-box;
  user-select: none;
}

.cardBgRoot .cardGameMedalH5 {
  display: flex;
  align-items: center;
  position: relative;
  height: 40px;
}


.cardBgRoot .cardGameMedal {
  position: relative;
  height: 100%;
  display: flex;
  align-items: center;
}

.cardGameMedal .medalImg {
  width: 33px;
  height: 33px;
  margin-right: 2px;
}

.cardBgRoot .cardGameMedal .textPrefix {
  font-weight: 600;
  font-size: 8px;
  line-height: 11px;
}

.cardBgRoot .cardGameMedal .starWrap {
  display: flex;
  height: 9px;
  margin-top: 2px;
}

.cardBgRoot .cardGameMedal .starWrap .starImg {
  width: 9px;
  height: 9px;
}
.cardBgRoot .cardGameMedal .starWrap .text {
  margin-left: 1px;
  font-weight: 500;
